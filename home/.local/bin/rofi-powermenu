#!/usr/bin/env bash

options="’Ćæ Shutdown\n’Ć× Reboot\n’ĆŻ Lock\n’ŗĄ Logout\n’åå Suspend"

chosen=$(echo -e "$options" | rofi -dmenu -p "Power" -config ~/.config/rofi/dmenu.rasi)

case "$chosen" in
    "’Ćæ Shutdown") systemctl poweroff ;;
    "’Ć× Reboot")   systemctl reboot ;;
    "’ĆŻ Lock")     /home/dell/.local/bin/lock ;;
    "’ŗĄ Logout")   i3-msg exit ;;
    "’åå Suspend")  systemctl suspend ;;
esac
